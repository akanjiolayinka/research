# ---- Required ----------------------------------------------------------------
# Free at https://console.groq.com (no card required).
GROQ_API_KEY=

# Free at https://app.pinecone.io (serverless tier, no card required).
PINECONE_API_KEY=


# ---- Optional (defaults shown) ----------------------------------------------
GROQ_MODEL=llama-3.3-70b-versatile

# Pinecone index will be auto-created on first request if it doesn't exist.
PINECONE_INDEX=rag-chatbot
PINECONE_CLOUD=aws
PINECONE_REGION=us-east-1

# Local embedding model. Downloads ~80MB on first startup.
# If you change this, also update embed_dim in app/config.py.
EMBED_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Retrieval / chunking knobs
CHUNK_SIZE=800
CHUNK_OVERLAP=120
TOP_K=5

# Frontend origins allowed to call the API (comma-separated).
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
