# ---- Required ----------------------------------------------------------------
# Free at https://console.groq.com (no card required).
GROQ_API_KEY=

# Free at https://app.pinecone.io (serverless tier, no card required).
PINECONE_API_KEY=


# ---- Models (defaults shown) ------------------------------------------------
GROQ_MODEL=llama-3.3-70b-versatile

# Local embedding model. Downloads ~80MB on first startup, then cached.
# If you change this, also update embed_dim in app/config.py.
EMBED_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Local cross-encoder reranker. Downloads ~90MB on first startup, then cached.
RERANK_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2


# ---- Pinecone (defaults shown) ----------------------------------------------
# The index is auto-created on first request if it doesn't exist.
PINECONE_INDEX=rag-chatbot
PINECONE_CLOUD=aws
PINECONE_REGION=us-east-1


# ---- Retrieval / chunking knobs ---------------------------------------------
# CHUNK_SIZE is a soft ceiling in CHARACTERS (sentences are never split).
CHUNK_SIZE=800
# CHUNK_OVERLAP is a max amount of trailing-sentence carryover, in characters.
CHUNK_OVERLAP=120

# How many chunks to retrieve from Pinecone before reranking.
TOP_K=10
# How many chunks to keep after the cross-encoder reranks them.
TOP_K_RERANK=3
# Guardrail: if the best rerank score is below this, return a "no relevant
# context" message and skip the LLM call entirely.
MIN_RERANK_SCORE=0.1


# ---- Conversation memory ----------------------------------------------------
# Number of recent (user + assistant) messages kept per session id.
# In-memory only — resets when the server restarts.
CONVERSATION_WINDOW=6


# ---- CORS -------------------------------------------------------------------
# Frontend origins allowed to call the API (comma-separated).
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
